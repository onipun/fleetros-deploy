---
# Production inventory template — generated by `make tofu-inventory` from tofu outputs.
# Copy to inventory/prod.yml and fill in the IP if you're going BYO-VPS without OpenTofu.
all:
  vars:
    ansible_user: deploy
    ansible_ssh_private_key_file: "~/.ssh/id_ed25519"
    fleetros_env: prod

  hosts:
    fleetros-prod:
      ansible_host: "REPLACE_WITH_VPS_IP"
