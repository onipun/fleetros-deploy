---
# Database credentials (consumed by data subchart).
#
# Two key namings live in this Secret:
#   * POSTGRES_USER / POSTGRES_PASSWORD — read by application Deployments
#     (platform subchart, Keycloak) as plain env vars.
#   * superuser-* / replication-* / authenticator-* — required key shape for
#     `SGCluster.spec.configurations.credentials` so StackGres uses our
#     password instead of generating its own random one.
apiVersion: v1
kind: Secret
metadata:
  name: postgres-creds
  namespace: data
type: Opaque
stringData:
  POSTGRES_USER: postgres
  POSTGRES_PASSWORD: {{ vault_postgres_password }}
  superuser-username: postgres
  superuser-password: {{ vault_postgres_password }}
  replication-username: replicator
  replication-password: {{ vault_postgres_password }}
  authenticator-username: authenticator
  authenticator-password: {{ vault_postgres_password }}
---
# Same creds mirrored into the app namespace for platform deployments
apiVersion: v1
kind: Secret
metadata:
  name: postgres-creds
  namespace: app
type: Opaque
stringData:
  POSTGRES_USER: postgres
  POSTGRES_PASSWORD: {{ vault_postgres_password }}
---
apiVersion: v1
kind: Secret
metadata:
  name: keycloak-admin
  namespace: data
type: Opaque
stringData:
  KEYCLOAK_ADMIN: admin
  KEYCLOAK_ADMIN_PASSWORD: {{ vault_keycloak_admin_password }}
---
# Argo CD Image Updater needs Docker Hub read creds + gitops repo write key
apiVersion: v1
kind: Secret
metadata:
  name: dockerhub-creds
  namespace: {{ argocd_namespace }}
  labels:
    argocd.argoproj.io/secret-type: repo-creds
type: Opaque
stringData:
  username: {{ vault_dockerhub_username }}
  password: {{ vault_dockerhub_token }}
---
apiVersion: v1
kind: Secret
metadata:
  name: gitops-ssh-key
  namespace: {{ argocd_namespace }}
type: Opaque
stringData:
  sshPrivateKey: |
{{ vault_gitops_ssh_deploy_key | indent(4, true) }}
---
# App-tier secrets (consumed by platform subchart)
apiVersion: v1
kind: Secret
metadata:
  name: app-secrets
  namespace: app
type: Opaque
stringData:
  STRIPE_SECRET_KEY: "{{ vault_stripe_secret_key | default('') }}"
  SMTP_HOST: "{{ vault_smtp_host | default('mailpit') }}"
  SMTP_PORT: "{{ vault_smtp_port | default(1025) | string }}"
  SMTP_USER: "{{ vault_smtp_user | default('') }}"
  SMTP_PASSWORD: "{{ vault_smtp_password | default('') }}"
  POSTGRES_PASSWORD: "{{ vault_postgres_password }}"
