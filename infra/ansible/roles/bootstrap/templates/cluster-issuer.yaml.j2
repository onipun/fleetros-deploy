{% if fleetros_env == "local" %}
# Local: a CA issuer backed by the mkcert root CA. Because mkcert's CA is
# trusted by the developer's browser (`mkcert -install` on the host), every
# cert issued from this ClusterIssuer is automatically trusted — no more
# "Your connection is not private" warnings on *.fleetros.local.
#
# The `mkcert-ca` Secret is seeded by the bootstrap role earlier in this
# playbook; it contains tls.crt + tls.key from `$(mkcert -CAROOT)` on the
# host that ran `make local-up`.
apiVersion: cert-manager.io/v1
kind: ClusterIssuer
metadata:
  name: fleetros-issuer
spec:
  ca:
    secretName: mkcert-ca
{% else %}
# Prod: Let's Encrypt with DNS-01. DNS-01 is REQUIRED for wildcard certs
# (e.g. `*.portal.{{ domain | default("example.com") }}`) — HTTP-01 cannot
# issue them. Variables come from group_vars/prod/main.yml + vault.yml.
apiVersion: cert-manager.io/v1
kind: ClusterIssuer
metadata:
  name: fleetros-issuer
spec:
  acme:
    server: {{ acme_server | default("https://acme-v02.api.letsencrypt.org/directory") }}
    email: {{ acme_email }}
    privateKeySecretRef:
      name: fleetros-le-account-key
    solvers:
      - dns01:
{% if acme_dns_provider == "cloudflare" %}
          cloudflare:
            apiTokenSecretRef:
              name: {{ acme_dns_secret_name | default("cloudflare-api-token") }}
              key: api-token
{% elif acme_dns_provider == "route53" %}
          route53:
            region: {{ acme_route53_region }}
            accessKeyIDSecretRef:
              name: {{ acme_dns_secret_name | default("route53-credentials") }}
              key: access-key-id
            secretAccessKeySecretRef:
              name: {{ acme_dns_secret_name | default("route53-credentials") }}
              key: secret-access-key
{% elif acme_dns_provider == "clouddns" %}
          cloudDNS:
            project: {{ acme_clouddns_project }}
            serviceAccountSecretRef:
              name: {{ acme_dns_secret_name | default("clouddns-sa") }}
              key: key.json
{% else %}
          # Unsupported provider "{{ acme_dns_provider }}" — extend this template.
{% endif %}
{% endif %}
